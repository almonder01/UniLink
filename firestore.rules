rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/profiles/$(uid);
    }

    function hasProfile(uid) {
      return exists(profilePath(uid));
    }

    function profile(uid) {
      return get(profilePath(uid));
    }

    function role() {
      return signedIn() && hasProfile(request.auth.uid)
        ? profile(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function clubPath(clubId) {
      return /databases/$(database)/documents/clubs/$(clubId);
    }

    function hasClub(clubId) {
      return exists(clubPath(clubId));
    }

    function clubDoc(clubId) {
      return get(clubPath(clubId));
    }

    function clubDetailEditPermissionPath(clubId, uid) {
      return /databases/$(database)/documents/club_detail_edit_permissions/$(clubId)/managers/$(uid);
    }

    function isClubManager(clubId) {
      return signedIn()
        && hasClub(clubId)
        && clubDoc(clubId).data.manager_id == request.auth.uid;
    }

    function hasActiveClubDetailEditPermission(clubId) {
      return signedIn()
        && exists(clubDetailEditPermissionPath(clubId, request.auth.uid))
        && get(clubDetailEditPermissionPath(clubId, request.auth.uid))
          .data.expires_at > request.time;
    }

    function clubDetailEditPermissionFields(clubId) {
      return get(clubDetailEditPermissionPath(clubId, request.auth.uid))
        .data
        .keys()
        .hasAny(['fields'])
        ? get(clubDetailEditPermissionPath(clubId, request.auth.uid))
          .data.fields
        : ['name', 'description'];
    }

    function hasClubDetailFieldPermission(clubId, field) {
      return hasActiveClubDetailEditPermission(clubId)
        && clubDetailEditPermissionFields(clubId).hasAny([field]);
    }

    function changedClubFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function clubIdentityDetailsUnchanged() {
      return !changedClubFields().hasAny([
        'name',
        'description',
        'logo_image_base64',
      ]);
    }

    function clubIdentityDetailChangesAllowed(clubId) {
      return (!changedClubFields().hasAny(['name'])
          || hasClubDetailFieldPermission(clubId, 'name'))
        && (!changedClubFields().hasAny(['description'])
          || hasClubDetailFieldPermission(clubId, 'description'))
        && (!changedClubFields().hasAny(['logo_image_base64'])
          || hasClubDetailFieldPermission(clubId, 'logo'));
    }

    function participantOfChat(chatId) {
      return signedIn()
        && get(/databases/$(database)/documents/direct_chats/$(chatId))
          .data.participant_ids
          .hasAny([request.auth.uid]);
    }

    match /profiles/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isClubManager(clubId)
          && (
            clubIdentityDetailsUnchanged()
            || clubIdentityDetailChangesAllowed(clubId)
          )
        );
    }

    match /user_follows/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /user_saved_posts/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && isClubManager(request.resource.data.clubId);
      allow delete: if signedIn() && (isAdmin() || isClubManager(resource.data.clubId));
      allow update: if signedIn();

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn()
          && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn() && isClubManager(request.resource.data.clubId);
      allow update, delete: if signedIn()
        && (isAdmin() || isClubManager(resource.data.clubId));
    }

    match /event_registrations/{registrationId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
          || isClubManager(resource.data.clubId)
        );
      allow delete: if signedIn()
        && (isAdmin() || isClubManager(resource.data.clubId));
    }

    match /club_memberships/{membershipId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (isAdmin() || isClubManager(request.resource.data.club_id));
      allow update, delete: if signedIn()
        && (isAdmin() || isClubManager(resource.data.club_id));
    }

    match /club_rooms/{roomId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isAdmin() || isClubManager(resource.data.club_id);

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if signedIn()
          && (resource.data.sender_id == request.auth.uid || isAdmin());
      }
    }

    match /direct_chats/{chatId} {
      allow read: if signedIn()
        && resource.data.participant_ids.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.participant_ids.hasAny([request.auth.uid]);
      allow update: if signedIn()
        && resource.data.participant_ids.hasAny([request.auth.uid]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if participantOfChat(chatId);
        allow create: if participantOfChat(chatId)
          && request.resource.data.sender_id == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{uid}/items/{notificationId} {
      allow read, update, delete: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn();
    }

    match /club_payment_requests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (isAdmin() || isClubManager(request.resource.data.club_id));
      allow update, delete: if signedIn()
        && (isAdmin() || isClubManager(resource.data.club_id));
    }

    match /club_payment_receipts/{receiptId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAdmin() || isClubManager(resource.data.club_id);
    }

    match /club_detail_edit_requests/{requestId} {
      allow get: if signedIn();
      allow list: if signedIn();
      allow create: if isAdmin()
        || (
          signedIn()
        && request.resource.data.manager_id == request.auth.uid
          && isClubManager(request.resource.data.club_id)
        );
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.manager_id == request.auth.uid
          && request.resource.data.manager_id == request.auth.uid
          && request.resource.data.status == 'pending'
          && isClubManager(request.resource.data.club_id)
        );
      allow delete: if isAdmin();
    }

    match /club_detail_edit_permissions/{clubId}/managers/{managerId} {
      allow read: if signedIn()
        && (request.auth.uid == managerId || isAdmin() || isClubManager(clubId));
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
